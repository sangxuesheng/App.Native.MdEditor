## cmd/main 标准模板

```bash
#!/bin/bash
LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

log_msg() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"; }

start_process() {
  if status; then return 0; fi
  log_msg "Starting..."
  bash -c "YOUR_START_CMD" >> "${LOG_FILE}" 2>&1 &
  printf "%s" "$!" > "${PID_FILE}"
}

stop_process() {
  if [ -r "${PID_FILE}" ]; then
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    kill -TERM "${pid}" 2>/dev/null
    sleep 2
    kill -KILL "${pid}" 2>/dev/null
    rm -f "${PID_FILE}"
  fi
}

status() {
  [ -f "${PID_FILE}" ] && kill -0 "$(cat ${PID_FILE})" 2>/dev/null
}

case $1 in
  start)  start_process; exit 0 ;;
  stop)   stop_process;  exit 0 ;;
  status) status && exit 0 || exit 3 ;;
  *)      exit 1 ;;
esac
```

> 错误处理：`echo "错误信息" > "${TRIM_TEMP_LOGFILE}"; exit 1` → 系统会弹窗展示给用户


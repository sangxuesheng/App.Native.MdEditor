# fnpack 打包排除文件
# 这个文件定义了 fnpack build 时应该忽略的文件和目录

# 开发文件和文档
*.md
*.MD
docs/
.git/
.gitignore
.cursor/
.trae/

# 构建和临时文件
*.log
*.tmp
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 前端开发文件
app/ui/frontend/node_modules/
app/ui/frontend/.vite/
app/ui/frontend/dist/**/*.map
app/ui/frontend/dist/**/*.js.map
app/ui/frontend/dist/**/*.css.map

# 服务端开发文件
app/server/node_modules/
app/server/.node-gyp/

# 历史和临时数据
app/shares/history/
app/var/
.trae/

# 测试和脚本
test_*.sh
test_*.html
diagnose_*.js
diagnose-*.sh
*.py
build_*.sh
build-*.sh
deploy.sh
快速*.sh
快速*.md

# 前端本地测试与构建脚本（运行时不需要）
app/ui/frontend/test*.html
app/ui/frontend/scripts/


# 打包产物（避免重复打包）
*.fpk
*.fpk.bak

# IDE 和编辑器
.vscode/
.idea/
*.swp
*.swo

#!/bin/bash

# 安装初始化脚本（install_init）
# - 安装前的环境检查与准备逻辑（保持幂等）

echo "App.Native.MdEditor install_init running..."

# 获取用户在向导中输入的端口
PORT="${wizard_port}"

# 如果没有配置端口，使用默认值
if [ -z "${PORT}" ]; then
    PORT="18080"
fi

echo "检查端口 ${PORT} 是否可用..."

# 检查端口是否被占用（使用 ss 命令）
if command -v ss >/dev/null 2>&1; then
    if ss -tuln | grep -q ":${PORT} "; then
        echo "错误：端口 ${PORT} 已被占用，请返回安装向导选择其他端口。" > "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
# 如果 ss 不可用，尝试使用 netstat
elif command -v netstat >/dev/null 2>&1; then
    if netstat -tuln 2>/dev/null | grep -q ":${PORT} "; then
        echo "错误：端口 ${PORT} 已被占用，请返回安装向导选择其他端口。" > "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
else
    echo "警告：无法检查端口占用情况（ss 和 netstat 命令均不可用），将继续安装。"
fi

echo "端口 ${PORT} 可用，继续安装..."

# 检查并安装 FFmpeg（用于 HEIC 图片格式转换）
echo "检查 FFmpeg 是否已安装..."
if ! command -v ffmpeg >/dev/null 2>&1; then
    echo "FFmpeg 未安装，正在安装..."
    
    # 检测操作系统并安装 FFmpeg
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        case "$ID" in
            debian|ubuntu)
                apt-get update && apt-get install -y ffmpeg
                ;;
            centos|rhel|fedora)
                if command -v dnf >/dev/null 2>&1; then
                    dnf install -y ffmpeg
                else
                    yum install -y epel-release && yum install -y ffmpeg
                fi
                ;;
            alpine)
                apk add --no-cache ffmpeg
                ;;
            *)
                echo "警告：无法自动安装 FFmpeg，HEIC 图片格式转换功能将不可用。"
                echo "请手动安装 FFmpeg: https://ffmpeg.org/download.html"
                ;;
        esac
    fi
    
    # 验证安装
    if command -v ffmpeg >/dev/null 2>&1; then
        echo "✓ FFmpeg 安装成功"
        ffmpeg -version | head -1
    else
        echo "警告：FFmpeg 安装失败，HEIC 图片格式转换功能将不可用。"
    fi
else
    echo "✓ FFmpeg 已安装"
    ffmpeg -version | head -1
fi

exit 0




### 2. AI 对话面板 - `AIAssistantPanel.vue` ⭐

**位置**: `apps/web/src/components/ai/chat-box/AIAssistantPanel.vue`

#### 核心功能

1. **流式对话**
   - 使用 Server-Sent Events (SSE) 接收流式响应
   - 实时显示 AI 回复内容
   - 支持暂停生成

2. **会话管理**
   - 自动保存当前会话
   - 加载历史会话
   - 删除会话
   - 新建会话

3. **快捷指令**
   - 预设 4 个默认指令（润色、翻译、总结）
   - 支持自定义指令
   - 使用 `{{sel}}` 占位符引用选中文本

4. **引用全文**
   - 将整篇 Markdown 作为上下文
   - 适合全文改写、总结等场景

#### 数据结构

```typescript
interface ChatMessage {
  role: `user` | `assistant` | `system`
  content: string
  reasoning?: string  // DeepSeek R1 的推理过程
  done?: boolean      // 是否生成完成
  id?: string         // 消息 ID
}

const messages = ref<ChatMessage[]>([])
```

#### 核心流程

```typescript
async function sendMessage() {
  // 1. 添加用户消息
  messages.value.push({ role: `user`, content: userInput })

  // 2. 创建 AI 回复消息（空内容）
  const replyMessage: ChatMessage = { 
    role: `assistant`, 
    content: ``, 
    done: false 
  }
  messages.value.push(replyMessage)

  // 3. 流式响应
  await streamResponse(replyMessage)
}

async function streamResponse(replyMessageProxy: ChatMessage) {
  // 构建上下文历史（最近 10 条消息）
  const contextHistory = messages.value.slice(-10)

  // 如果启用"引用全文"，添加系统消息
  const quoteMessages = isQuoteAllContent.value
    ? [{
        role: `system`,
        content: `下面是一篇 Markdown 文章全文：\n\n${editor.value?.state.doc.toString()}`
      }]
    : []

  // 构建请求 payload
  const payload = {
    model: model.value,
    messages: [
      { role: `system`, content: `你是一个专业的 Markdown 编辑器助手` },
      ...quoteMessages,
      ...contextHistory,
    ],
    temperature: temperature.value,
    max_tokens: maxToken.value,
    stream: true,  // 启用流式响应
  }

  // 发送请求
  const res = await fetch(endpoint.value, {
    method: `POST`,
    headers: {
      'Content-Type': `application/json`,
      'Authorization': `Bearer ${apiKey.value}`,
    },
    body: JSON.stringify(payload),
  })

  // 读取流式响应
  const reader = res.body.getReader()
  const decoder = new TextDecoder(`utf-8`)
  let buffer = ``

  while (true) {
    const { value, done } = await reader.read()
    if (done) break

    buffer += decoder.decode(value, { stream: true })
    const lines = buffer.split(`\n`)
    buffer = lines.pop() || ``

    for (const line of lines) {
      if (!line.trim() || line.trim() === `data: [DONE]`) continue
      
      try {
        const json = JSON.parse(line.replace(/^data: /, ``))
        const delta = json.choices?.[0]?.delta || {}
        
        // 更新消息内容
        if (delta.content) {
          replyMessageProxy.content += delta.content
        }
        
        // DeepSeek R1 的推理过程
        if (delta.reasoning_content) {
          replyMessageProxy.reasoning = (replyMessageProxy.reasoning || ``) + delta.reasoning_content
        }
        
        await scrollToBottom()
      } catch {}
    }
  }

  // 标记完成
  replyMessageProxy.done = true
  
  // 保存到 localStorage
  await store.setJSON(memoryKey, messages.value)
  await autoSaveCurrentConversation()
}
```


### 4. 自动滚动到底部

```typescript
async function scrollToBottom(force = false) {
  await nextTick()
  const container = document.querySelector(`.chat-container`)
  if (container) {
    const isNearBottom = (container.scrollTop + container.clientHeight)
      >= (container.scrollHeight - 50)
    
    // 只有在接近底部或强制滚动时才滚动
    if (force || isNearBottom) {
      container.scrollTop = container.scrollHeight
    }
  }
}
```

### 5. 输入历史记录

支持 ↑↓ 键浏览历史输入：

```typescript
const inputHistory = ref<string[]>([])
const historyIndex = ref<number | null>(null)

function handleKeydown(e: KeyboardEvent) {
  if (e.key === `ArrowUp`) {
    e.preventDefault()
    if (historyIndex.value === null) {
      historyIndex.value = inputHistory.value.length - 1
    } else if (historyIndex.value > 0) {
      historyIndex.value--
    }
    input.value = inputHistory.value[historyIndex.value] || ``
  }
  else if (e.key === `ArrowDown`) {
    e.preventDefault()
    if (historyIndex.value !== null) {
      if (historyIndex.value < inputHistory.value.length - 1) {
        historyIndex.value++
        input.value = inputHistory.value[historyIndex.value] || ``
      } else {
        historyIndex.value = null
        input.value = ``
      }
    }
  }
}
```

## 🔒 安全性

1. **API Key 加密存储**
   - 存储在 localStorage
   - 按服务类型分别存储
   - 不会发送到服务器

2. **请求验证**
   - 测试连接功能验证端点可用性
   - 错误处理和提示

3. **内容过滤**
   - 使用 DOMPurify 防止 XSS
   - 限制上下文长度


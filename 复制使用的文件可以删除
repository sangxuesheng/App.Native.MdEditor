2. **按服务分别存储 API Key**
   ```typescript
   // API Key 按服务类型分别持久化
   const apiKey = customRef<string>((track, trigger) => {
     let cachedKey = ``

     // 异步加载初始值
     store.get(`openai_key_${type.value}`).then((value) => {
       cachedKey = value || ``
     })

     return {
       get() {
         track()
         return cachedKey
       },
       set(val: string) {
         cachedKey = val
         trigger()
         
         // 保存到 localStorage
         if (type.value !== `default`) {
           store.set(`openai_key_${type.value}`, val)
         }
       },
     }
   })
   ```

3. **自动同步端点和模型**
   ```typescript
   // 监听服务类型变化
   watch(type, async (newType) => {
     const svc = serviceOptions.find(s => s.value === newType)
     
     // 更新端点
     endpoint.value = svc.endpoint
     
     // 读取已保存的模型
     const saved = await store.get(`openai_model_${newType}`)
     model.value = svc.models.includes(saved) ? saved : svc.models[0]
   }, { immediate: true })
   ```


<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <!-- 核心优化1：增强移动端适配元标签 -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>Markdown 极简动态占位图</title>
    <style>
        :root {
            --skeleton-gray: #E2E8F0;
            --dark-sky-blue: #1E293B;
            --shimmer-silver: #F8FAFC;
            --accent-glow: rgba(56, 189, 248, 0.3);
            --text-color: #94A3B8;
            --font-main: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "Noto Sans SC", sans-serif;
            /* 新增：基础尺寸变量，方便适配 */
            --base-size: clamp(10px, 2vw, 20px);
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: transparent;
            /* 核心优化2：强化居中布局，兼容所有设备 */
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-main);
            overflow: hidden;
            /* 防止移动端滚动条 */
            touch-action: none;
        }

        .canvas-container {
            /* 核心优化3：自适应容器，限制最大尺寸，适配不同设备 */
            width: 100%;
            height: 100%;
            max-width: 90vw;  /* 平板/手机占屏幕90%宽度 */
            max-height: 80vh; /* 高度不超过屏幕80%，避免溢出 */
            /* 强制居中，兼容flex失效场景 */
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: center;
            /* 保持SVG比例 */
            aspect-ratio: 1200 / 700;
        }

        svg {
            /* 核心优化4：SVG自适应缩放，始终居中 */
            width: 100%;
            height: 100%;
            /* 确保SVG内部元素按比例缩放 */
            preserveAspectRatio: xMidYMid meet;
            filter: drop-shadow(0 10px 20px rgba(0,0,0,0.05));
        }

        /* 1. 边框描边：仅顺时针描边，无旋转 */
        .border-draw {
            stroke-dasharray: 1360; /* 外框周长 (440+240)*2 */
            stroke-dashoffset: 1360;
            animation: borderDraw 2.5s cubic-bezier(0.45, 0.05, 0.55, 0.95) forwards;
        }

        @keyframes borderDraw {
            0% { stroke-dashoffset: 1360; opacity: 0; }
            20% { opacity: 1; }
            100% { stroke-dashoffset: 0; opacity: 1; }
        }

        /* 2. Logo（M+箭头）：顺时针旋转 + 逐步描边 */
        .logo-draw {
            stroke-dasharray: 1200;
            stroke-dashoffset: 1200;
            transform-origin: 600px 350px; /* logo中心旋转 */
            /* 旋转+描边同步动画 */
            animation: 
                logoDraw 2.5s cubic-bezier(0.45, 0.05, 0.55, 0.95) forwards,
                logoRotate 2.5s cubic-bezier(0.45, 0.05, 0.55, 0.95) forwards;
        }

        /* Logo描边动画 */
        @keyframes logoDraw {
            0% { stroke-dashoffset: 1200; opacity: 0; }
            20% { opacity: 1; }
            100% { stroke-dashoffset: 0; opacity: 1; }
        }

        /* Logo顺时针旋转动画（0→360°） */
        @keyframes logoRotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* 第二阶段：呼吸效果（logo整体） */
        .breathing-group {
            transform-origin: 600px 350px;
            animation: breathScale 4s ease-in-out infinite 2.5s;
        }

        @keyframes breathScale {
            0%, 100% { transform: scale(0.97); }
            50% { transform: scale(1.03); }
        }

        /* 第二阶段：高光扫过 */
        .shimmer-rect {
            fill: url(#shimmerGradient);
            animation: shimmerMove 3s infinite linear 2.5s;
        }

        @keyframes shimmerMove {
            0% { transform: translateX(-600px) skewX(-30deg); }
            100% { transform: translateX(1000px) skewX(-30deg); }
        }

        /* 第三阶段：箭头微动 */
        .arrow-group {
            animation: arrowFloat 2s ease-in-out infinite 2.5s;
        }

        @keyframes arrowFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(12px); }
        }

        /* 文字与装饰点淡入 - 适配移动端字体大小 */
        .fade-in {
            opacity: 0;
            animation: fadeInAnim 1.5s ease-out 3s forwards;
        }

        @keyframes fadeInAnim {
            to { opacity: 1; }
        }

        /* 核心优化5：响应式字体，适配不同设备 */
        .status-text {
            font-size: var(--base-size);
            letter-spacing: 1px; /* 移动端减少字间距，避免换行 */
        }

        /* 磨砂质感层 */
        .frosted-layer {
            fill: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(2px);
        }

        /* 核心优化6：媒体查询，针对小屏手机精细调整 */
        @media (max-width: 480px) {
            .canvas-container {
                max-height: 70vh; /* 手机端进一步降低高度占比 */
            }
            /* 缩小加载点尺寸，适配手机 */
            .loading-dot {
                r: 2.5 !important;
            }
            /* 调整箭头微动幅度，适配小屏 */
            @keyframes arrowFloat {
                0%, 100% { transform: translateY(0); }
                50% { transform: translateY(8px); }
            }
        }

        /* 核心优化7：平板横屏适配 */
        @media (min-width: 768px) and (max-width: 1024px) and (orientation: landscape) {
            .canvas-container {
                max-width: 70vw;
                max-height: 90vh;
            }
        }
    </style>
</head>
<body>

<div class="canvas-container">
    <svg viewBox="0 0 1200 700" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <!-- 高光渐变 -->
            <linearGradient id="shimmerGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="transparent" />
                <stop offset="50%" stop-color="rgba(255, 255, 255, 0.6)" />
                <stop offset="100%" stop-color="transparent" />
            </linearGradient>

            <!-- 骨架屏渐变 -->
            <linearGradient id="skeletonGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#F1F5F9" />
                <stop offset="100%" stop-color="#E2E8F0" />
            </linearGradient>

            <!-- 边缘微光滤镜 -->
            <filter id="edgeGlow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="6" result="blur" />
                <feComposite in="SourceGraphic" in2="blur" operator="over" />
            </filter>

            <!-- 剪切路径：限制高光在图标内 -->
            <clipPath id="iconClip">
                <rect x="380" y="230" width="440" height="240" rx="24" />
            </clipPath>
        </defs>

        <!-- 装饰性背景元素 -->
        <g opacity="0.4">
            <circle cx="200" cy="150" r="80" fill="var(--skeleton-gray)" opacity="0.2" />
            <circle cx="1000" cy="550" r="120" fill="var(--dark-sky-blue)" opacity="0.05" />
        </g>

        <!-- 动画主体容器 -->
        <g class="breathing-group">
            
            <!-- 1. 外框：磨砂质感 -->
            <rect x="380" y="230" width="440" height="240" rx="24" 
                  fill="url(#skeletonGradient)" fill-opacity="0.8" 
                  stroke="var(--dark-sky-blue)" stroke-width="1.5" stroke-opacity="0.1" />
            
            <!-- 边框描边层：仅顺时针描边，无旋转 -->
            <rect x="380" y="230" width="440" height="240" rx="24" 
                  fill="none" stroke="var(--dark-sky-blue)" stroke-width="3" 
                  stroke-linecap="round" class="border-draw" />

            <!-- 2. Markdown 字符 M (左侧)：旋转+描边 -->
            <path d="M440 400 V300 L490 350 L540 300 V400" 
                  fill="none" stroke="var(--dark-sky-blue)" stroke-width="24" 
                  stroke-linecap="round" stroke-linejoin="round"
                  class="logo-draw" style="animation-delay: 0.4s;" />

            <!-- 3. 向下箭头组合 (右侧)：旋转+描边 -->
            <g class="arrow-group">
                <!-- 箭头竖杠 -->
                <line x1="700" y1="300" x2="700" y2="400" 
                      stroke="var(--dark-sky-blue)" stroke-width="24" stroke-linecap="round" 
                      class="logo-draw" style="animation-delay: 0.8s;" />
                <!-- 箭头尖端 -->
                <path d="M640 350 L700 410 L760 350" 
                      fill="none" stroke="var(--dark-sky-blue)" stroke-width="24" 
                      stroke-linecap="round" stroke-linejoin="round"
                      class="logo-draw" style="animation-delay: 1.2s;" />
            </g>

            <!-- 4. 高光扫过层 -->
            <g clip-path="url(#iconClip)">
                <rect class="shimmer-rect" x="0" y="230" width="200" height="240" />
            </g>

            <!-- 5. 边缘微光 -->
            <rect x="380" y="230" width="440" height="240" rx="24" 
                  fill="none" stroke="var(--accent-glow)" stroke-width="2" 
                  filter="url(#edgeGlow)" opacity="0.5" />
        </g>

        <!-- 底部状态提示 - 增加类名适配响应式 -->
        <g class="fade-in">
            <text x="600" y="540" text-anchor="middle" class="status-text" fill="var(--text-color)" font-weight="300">
                正在初始化编辑环境
            </text>
            
            <!-- 动态加载点 - 增加类名适配响应式 -->
            <g transform="translate(570, 575)">
                <circle cx="0" cy="0" class="loading-dot" fill="var(--text-color)">
                    <animate attributeName="opacity" values="0.2;1;0.2" dur="1.8s" repeatCount="indefinite" begin="0s" />
                </circle>
                <circle cx="30" cy="0" class="loading-dot" fill="var(--text-color)">
                    <animate attributeName="opacity" values="0.2;1;0.2" dur="1.8s" repeatCount="indefinite" begin="0.3s" />
                </circle>
                <circle cx="60" cy="0" class="loading-dot" fill="var(--text-color)">
                    <animate attributeName="opacity" values="0.2;1;0.2" dur="1.8s" repeatCount="indefinite" begin="0.6s" />
                </circle>
            </g>
        </g>
    </svg>
</div>

<script>
    /**
     * 极简交互与性能优化 + 移动端适配增强
     */
    document.addEventListener('DOMContentLoaded', () => {
        const svgElement = document.querySelector('svg');
        const canvasContainer = document.querySelector('.canvas-container');
        
        // 模拟移动端点击反馈
        svgElement.addEventListener('pointerdown', () => {
            svgElement.style.transition = 'transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
            svgElement.style.transform = 'scale(0.96)';
        });

        document.addEventListener('pointerup', () => {
            svgElement.style.transform = 'scale(1)';
        });

        // 核心优化8：窗口变化时强制重绘，确保居中
        const handleResize = () => {
            // 更新vh变量
            const vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
            
            // 强制容器居中（兼容部分浏览器flex布局失效）
            canvasContainer.style.left = `${(window.innerWidth - canvasContainer.offsetWidth) / 2}px`;
            canvasContainer.style.top = `${(window.innerHeight - canvasContainer.offsetHeight) / 2}px`;
        };

        // 监听窗口变化（包括旋转屏幕）
        window.addEventListener('resize', handleResize);
        window.addEventListener('orientationchange', handleResize);
        
        // 初始化执行一次
        handleResize();
    });

    // 针对移动端首屏加载的静默处理
    console.log("%c Markdown Loader %c Ready ", "color: #fff; background: #1E293B; padding: 2px 4px; border-radius: 3px 0 0 3px;", "color: #fff; background: #38BDF8; padding: 2px 4px; border-radius: 0 3px 3px 0;");
</script>

</body>
</html>